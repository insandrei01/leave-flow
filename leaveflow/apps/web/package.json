{
  "name": "@leaveflow/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf dist .next",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "firebase": "^10.12.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "@leaveflow/constants": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.3",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "Node"
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "collectCoverageFrom": [
      "src/stores/**/*.ts",
      "src/hooks/**/*.ts",
      "src/lib/**/*.ts",
      "src/components/**/*.tsx",
      "!src/**/*.d.ts"
    ]
  }
}
