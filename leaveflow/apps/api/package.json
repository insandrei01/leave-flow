    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1",
    "mongoose": "^8.9.0",
    "ioredis": "^5.3.2",
    "bullmq": "^5.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "mongodb-memory-server": "^10.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
