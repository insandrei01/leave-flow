        {
          "type": "button",
          "text": {
            "type": "plain_text",
            "text": "View in LeaveFlow",
            "emoji": true
          },
          "action_id": "view_in_app",
          "url": "https://app.leaveflow.com/requests/REQ-2026-0147"
