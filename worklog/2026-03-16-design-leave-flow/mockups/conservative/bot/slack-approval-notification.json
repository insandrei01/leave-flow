          "text": "*Type:*\n:palm_tree: Vacation"
        },
        {
          "type": "mrkdwn",
          "text": "*Days:*\n5 working days"
        },
        {
          "type": "mrkdwn",
          "text": "*Dates:*\nMar 24 - Mar 28, 2026"
        },
